generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:/Users/boramos/Developer/details-bymima/prisma/dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  phone         String?
  role          String  @default("CUSTOMER") // ADMIN | CUSTOMER
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  addresses       Address[]
  orders          Order[]
  passport        PassportSubscription?
  autoBuys        AutoBuy[]
  cart            CartItem[]

  @@index([email])
}

// Removed enum UserRole - SQLite uses String type

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Address {
  id               String  @id @default(cuid())
  userId           String
  street           String
  city             String
  postalCode       String
  country          String  @default("United States")
  deliveryInstructions String?
  isDefault        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([userId, isDefault])
}

model Product {
  id             String   @id @default(cuid())
  slug           String   @unique
  nameEs         String
  nameEn         String
  descriptionEs  String
  descriptionEn  String
  longDescriptionEs String?
  longDescriptionEn String?
  basePriceCop   Int
  imageEmoji     String
  gradientClass  String
  bestSeller     Boolean  @default(false)
  active         Boolean  @default(true)
  
  categories     String
  colors         String
  styles         String
  tags           String
  
  optionGroups   String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems  OrderItem[]
  cartItems   CartItem[]
  autoBuys    AutoBuy[]

  @@index([slug])
  @@index([bestSeller])
  @@index([active])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String
  
  subtotalCop     Int
  taxCop          Int
  deliveryFeeCop  Int
  discountCop     Int         @default(0)
  totalCop        Int
  
  status          String @default("PENDING") // PENDING | CONFIRMED | PREPARING | OUT_FOR_DELIVERY | DELIVERED | CANCELLED
  
  customerName    String
  customerEmail   String
  customerPhone   String
  
  deliveryMethod  String // PICKUP | STANDARD | TOMORROW | TODAY
  deliveryAddressId String?
  deliveryAddress   Address?   @relation(fields: [deliveryAddressId], references: [id])
  scheduledDeliveryDate DateTime?
  actualDeliveryDate    DateTime?
  
  paymentMethod   String // CARD | PAYPAL
  paymentStatus   String @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  stripeSessionId String?
  paypalOrderId   String?
  paidAt          DateTime?
  
  notes           String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
}

// Removed enums OrderStatus, DeliveryMethod, PaymentMethod, PaymentStatus - SQLite uses String types

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  productId    String
  
  productSlug  String
  productName  String
  quantity     Int
  unitPriceCop Int
  lineTotalCop Int
  
  selections   String
  note         String?
  
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model CartItem {
  id         String   @id @default(cuid())
  userId     String
  productId  String
  
  quantity   Int      @default(1)
  selections   String // JSON string
  note       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId, note])
  @@index([userId])
}

model PassportSubscription {
  id            String               @id @default(cuid())
  userId        String               @unique
  
  status        String   @default("ACTIVE") // ACTIVE | EXPIRED | CANCELLED | PAUSED
  startDate     DateTime
  endDate       DateTime
  pricePaidCop  Int
  
  stripeSubscriptionId String?
  paypalSubscriptionId String?
  
  autoRenew     Boolean              @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// Removed enum SubscriptionStatus - SQLite uses String type

model AutoBuy {
  id                String           @id @default(cuid())
  userId            String
  productId         String
  
  quantity          Int              @default(1)
  selections        String // JSON string
  
  frequency         String // WEEKLY | BIWEEKLY | MONTHLY
  startDate         DateTime
  endDate           DateTime?
  nextScheduledDate DateTime
  
  status            String    @default("ACTIVE") // ACTIVE | PAUSED | CANCELLED | COMPLETED
  
  reminderEnabled   Boolean          @default(true)
  reminderDaysBefore Int             @default(3)
  
  deliveryAddressId String?
  paymentMethod     String // CARD | PAYPAL
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product            @relation(fields: [productId], references: [id])
  executionLog AutoBuyExecution[]

  @@index([userId])
  @@index([status])
  @@index([nextScheduledDate])
}

// Removed enums AutoBuyFrequency, AutoBuyStatus - SQLite uses String types

model AutoBuyExecution {
  id          String   @id @default(cuid())
  autoBuyId   String
  orderId     String?
  
  scheduledFor DateTime
  executedAt   DateTime @default(now())
  status       String
  errorMessage String?
  
  autoBuy AutoBuy @relation(fields: [autoBuyId], references: [id], onDelete: Cascade)

  @@index([autoBuyId])
  @@index([scheduledFor])
}

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  valueType   String   @default("string") // string | number | boolean | json
  description String?
  category    String   @default("general") // general | pricing | delivery | tax | features
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([category])
}
